{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es2022", "dom"],
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["types-for-adobe/Illustrator/2015.3", "vitest/globals"],
    "paths": {
      "*": ["./src/types.d.ts"]
    }
  },
  "include": ["src"]
}
